''
  * {
    border: none;
    border-radius: 10px;
    min-height: 0;
    font-family: Inter, sans-serif;
    font-size: 11pt;
  }

  window#waybar {
    background: transparent;
  }

  #workspaces,
  #clock,
  #crypto,
  #cpu,
  #memory,
  #temperature,
  #network,
  #bluetooth,
  #pulseaudio,
  #backlight,
  #battery,
  #tray,
  #custom-notification,
  #powermenu {
    background: rgba(36, 49, 99, 0.85);
    padding: 0.35rem 0.6rem;
    margin: 0 2px;
  }

  #workspaces button.active {
    background: rgba(255,255,255,0.15);
  }

  #custom-power {
    color: #f38ba8;
  }
''
